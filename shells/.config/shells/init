# Determine current shell
if [ -n "$ZSH_VERSION" ]; then
  CURRENT_SHELL="zsh"
elif [ -n "$BASH_VERSION" ]; then
  CURRENT_SHELL="bash"
else
  CURRENT_SHELL="bash" # fallback
fi

if command -v mise &> /dev/null; then
  eval "$(mise activate $CURRENT_SHELL)"
fi

if [[ $- == *i* ]] && [[ ${TERM:-} != "dumb" ]] && command -v starship &> /dev/null; then
  eval "$(starship init $CURRENT_SHELL)"
fi

if command -v zoxide &> /dev/null; then
  eval "$(zoxide init $CURRENT_SHELL --cmd cd)"
fi

if command -v try &> /dev/null; then
  eval "$(SHELL=/bin/$CURRENT_SHELL command try init ~/Work/tries)"
fi

if command -v fzf &> /dev/null; then
  if [[ -f .config/fzf/completion.$CURRENT_SHELL ]]; then
    source .config/fzf/completion.$CURRENT_SHELL
  fi
  if [[ -f .config/fzf/key-bindings.$CURRENT_SHELL ]]; then
    source .config/fzf/key-bindings.$CURRENT_SHELL
  fi
fi

if command -v atuin &> /dev/null; then
  eval "$(atuin init $CURRENT_SHELL)"
fi

# Tealdeer — register built-in Zsh completions (generated once, cached)
# Supersedes the old compctl plugin approach (g0t4/dotfiles)
if [[ "$CURRENT_SHELL" == "zsh" ]] && command -v tldr &> /dev/null; then
  _tldr_comp_dir="${ZDOTDIR:-$HOME}/.zsh/completions"
  _tldr_comp_file="$_tldr_comp_dir/_tldr"
  if [[ ! -f "$_tldr_comp_file" ]]; then
    mkdir -p "$_tldr_comp_dir"
    tldr --print-completions zsh > "$_tldr_comp_file" 2>/dev/null
  fi
  if [[ ":$FPATH:" != *":$_tldr_comp_dir:"* ]]; then
    export FPATH="$_tldr_comp_dir:$FPATH"
  fi
  unset _tldr_comp_dir _tldr_comp_file
fi